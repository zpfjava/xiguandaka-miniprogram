/* 学习计划页样式 */
.plans-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
}

/* 顶部标题 */
.page-header {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 30rpx 30rpx 36rpx;
}

.header-title { font-size: 38rpx; font-weight: bold; color: #333333; }
.header-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-top: 8rpx; }

/* 新增计划按钮栏 */
.add-plan-bar {
  padding: 20rpx 30rpx 0;
}

.add-plan-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #FFFFFF;
  color: #FF9A3C;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  text-align: center;
  border: 2rpx dashed #FF9A3C;
  padding: 20rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(255, 154, 60, 0.08);
}

.add-plan-btn:active { opacity: 0.75; background: #FFF5E6; }

.add-icon { font-size: 36rpx; font-weight: bold; }

/* 打卡状态占位（加载中） */
.checkin-placeholder {
  background: transparent;
  color: #CCCCCC;
  font-size: 26rpx;
  border: none;
}
.add-plan-btn::after { border: none; }
.add-plan-btn:active { opacity: 0.85; }

/* 计划列表 */
.plan-list { padding: 24rpx 30rpx 0; }

/* 计划卡片 */
.plan-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.plan-card.inactive {
  opacity: 0.55;
}
.plan-card.active { border-left: 8rpx solid #7ED957; }

/* 暂停状态：图标和标题变灰 */
.icon-gray {
  filter: grayscale(100%);
  opacity: 0.5;
}
.title-gray {
  color: #999999 !important;
}

/* 暂停标签 */
.paused-badge {
  display: inline-block;
  font-size: 20rpx;
  color: #F44336;
  background-color: #FFEBEE;
  padding: 2rpx 14rpx;
  border-radius: 9999rpx;
  margin-top: 6rpx;
}

/* 计划头部 */
.plan-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.plan-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E1;
  border-radius: 20rpx;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.plan-info { flex: 1; }
.plan-title { font-size: 32rpx; font-weight: bold; color: #333333; }
.plan-meta { 
  font-size: 24rpx; 
  color: #999999; 
  margin-top: 6rpx; 
}
.divider { margin: 0 10rpx; }

/* 进度条 */
.plan-progress { margin-bottom: 18rpx; }
.progress-bar {
  height: 12rpx;
  background-color: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FFD93D 0%, #FF9A3C 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}
.progress-text { font-size: 22rpx; color: #999999; }

/* 操作按钮 */
.plan-actions {
  display: flex;
  gap: 14rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
}

.action-btn {
  text-align: center;
  font-size: 24rpx;
  border-radius: 32rpx;
  border: none;
  padding: 0;
  height: 64rpx;
  line-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.action-btn::after { border: none; }

.checkin-btn-card {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-weight: bold;
}
.checkin-btn-card:active { opacity: 0.85; }

/* 已打卡按钮：绿色完成态 */
.checkedin-btn-card {
  background: linear-gradient(135deg, #7ED957 0%, #5CB85C 100%);
  color: #FFFFFF !important;
  font-weight: bold;
  font-size: 24rpx;
  border-radius: 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  min-width: 140rpx;
}

/* 已暂停状态：去打卡按钮变灰 */
.checkin-btn-disabled {
  background-color: #F0F0F0;
  color: #999999;
  font-size: 24rpx;
  border-radius: 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
}

/* 暂停状态下操作区域：显示提示文字 */
.paused-actions-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  height: 64rpx;
  font-size: 22rpx;
  color: #999999;
  background-color: #FAFAFA;
  border-radius: 16rpx;
}
.paused-icon { font-size: 28rpx; }

.edit-btn {
  background-color: #F0F0F0;
  color: #666666;
}
.edit-btn:active { opacity: 0.7; }

.delete-btn {
  background-color: #FFEBEE;
  color: #F44336;
}
.delete-btn:active { opacity: 0.7; }

/* 非打卡时间按钮 */
.rest-day-btn {
  background-color: #F5F5F5;
  color: #AAAAAA;
  font-size: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 32rpx; color: #666666; margin-bottom: 12rpx; }
.empty-desc { font-size: 26rpx; color: #999999; margin-bottom: 30rpx; text-align: center; line-height: 1.5; }
.empty-btn {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 48rpx;
  border-radius: 9999rpx;
}

/* 底部提示 */
.tips-section {
  display: flex;
  align-items: flex-start;
  margin: 30rpx 30rpx;
  padding: 24rpx;
  background-color: #FFFDE7;
  border-radius: 16rpx;
}
.tips-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.tips-content { flex: 1; }
.tips-title { font-size: 26rpx; font-weight: bold; color: #333333; }
.tips-text { font-size: 24rpx; color: #666666; margin-top: 6rpx; line-height: 1.5; }

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.plan-modal {
  width: 600rpx;
  max-height: 80vh;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  /* iOS 兼容：阻止弹窗本身成为滚动容器，让 modal-body 独立滚动 */
  overflow-y: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #F0F0F0;
  /* iOS 兼容：header 不被压缩 */
  flex-shrink: 0;
}

/* modal-body：唯一可滚动的区域，使用 flex 布局确保 iOS 滚动稳定 */
.modal-body { 
  padding: 30rpx; 
  overflow-y: auto; 
  -webkit-overflow-scrolling: touch;
  flex: 1;
  min-height: 0;
}

.form-group { margin-bottom: 28rpx; }
.form-label { font-size: 28rpx; font-weight: bold; color: #333333; margin-bottom: 12rpx; display: block; }

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.form-input:focus { border-color: #FFD93D; background-color: #FFFFFF; }

.form-picker {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer button {
  text-align: center;
  font-size: 30rpx;
  background: none;
  border: none;
  height: 96rpx;
  line-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.modal-footer button::after { border: none; }
.cancel-btn { color: #999999; border-right: 1rpx solid #F0F0F0 !important; }
.confirm-btn { color: #FF9A3C; font-weight: bold; }
.confirm-btn[disabled] { color: #CCCCCC; }

/* 按钮加载态：半透明 + 降低对比度，让用户直观感受到"正在处理" */
.confirm-btn.btn-loading {
  opacity: 0.6;
  color: #CCCCCC !important;
}

/* 自定义频率：星期选择器 */
.weekday-selector {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.weekday-item {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.weekday-item:active {
  transform: scale(0.92);
}

.weekday-selected {
  color: #FFFFFF !important;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%) !important;
  border-color: #FF9A3C;
  font-weight: bold;
}

.weekday-hint {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 12rpx;
  text-align: center;
}

.target-hint {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}
