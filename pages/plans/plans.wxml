<!-- 小打卡 - 学习计划页 -->
<view class="plans-page">
  <!-- 顶部标题 -->
  <view class="page-header">
    <view class="header-title">📚 我的学习计划</view>
    <view class="header-subtitle">坚持每天打卡，养成好习惯</view>
  </view>

  <!-- 计划列表 -->
  <block wx:if="{{plans.length > 0}}">
    <!-- 新增按钮（始终显示） -->
    <view class="add-plan-bar">
      <view class="add-plan-btn" bindtap="showAddModal">
        <text class="add-icon">+</text>
        <text>新增学习计划</text>
      </view>
    </view>

    <view class="plan-list">
      <view 
        wx:for="{{plans}}" 
        wx:key="_id" 
        class="plan-card {{item.isActive ? 'active' : 'inactive'}}"
      >
        <!-- 计划头部 -->
        <view class="plan-header">
          <view class="plan-icon {{item.isActive ? '' : 'icon-gray'}}">{{item.subjectIcon || '📝'}}</view>
          <view class="plan-info">
            <view class="plan-title {{item.isActive ? '' : 'title-gray'}}">{{item.title}}</view>
            <view class="plan-meta">
              <text>{{item.subject}}</text>
              <text class="divider">·</text>
              <text>{{item.frequency}}</text>
            </view>
            <!-- 暂停状态标签 -->
            <view class="paused-badge" wx:if="{{!item.isActive}}">已暂停</view>
          </view>
          <switch
            checked="{{item.isActive}}"
            color="#7ED957"
            bindchange="togglePlanActive"
            data-id="{{item.id || item._id}}"
          />
        </view>

        <!-- 计划进度 -->
        <view class="plan-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progressPercent || 0}}%"></view>
          </view>
          <view class="progress-text">
            已完成 {{item.completedCount || 0}}/{{item.totalCount || 30}} 次
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="plan-actions">
          <block wx:if="{{item.isActive}}">
            <!-- 已打卡：显示已完成 -->
            <block wx:if="{{item.checkedInToday === true}}">
              <button class="action-btn checkedin-btn-card" disabled>✓ 已完成</button>
            </block>
            <!-- 未打卡或状态未知 -->
            <block wx:else>
              <!-- 非打卡日（按频率判断）：显示禁用按钮 -->
              <block wx:if="{{item.isCheckinDay === false}}">
                <button class="action-btn rest-day-btn" disabled>📅 非打卡时间</button>
              </block>
              <!-- 打卡日：显示去打卡 -->
              <block wx:else>
                <button
                  class="action-btn checkin-btn-card"
                  data-plan="{{item}}"
                  bindtap="goToCheckin"
                >去打卡</button>
              </block>
            </block>
            <button
              class="action-btn edit-btn"
              data-item="{{item}}"
              bindtap="editPlan"
            >编辑</button>
            <button
              class="action-btn delete-btn"
              data-id="{{item.id || item._id}}"
              bindtap="deletePlan"
            >删除</button>
          </block>
          <block wx:else>
            <view class="paused-actions-hint">
              <text class="paused-icon">⏸</text>
              <text>计划已暂停，点击右上角开关恢复</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="empty-state">
      <view class="empty-icon">🌱</view>
      <view class="empty-text">还没有学习计划哦</view>
      <view class="empty-desc">创建你的第一个学习计划，开始养成好习惯吧！</view>
      <view class="empty-btn" bindtap="showAddModal">+ 创建第一个计划</view>
    </view>
  </block>

  <!-- 底部提示 -->
  <view class="tips-section">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-title">小贴士</view>
      <view class="tips-text">建议每天设置 2-3 个学习任务，更容易坚持完成哦~</view>
    </view>
  </view>
</view>

<!-- 新建/编辑计划弹窗 -->
<view class="modal-overlay" wx:if="{{showModal}}">
  <view class="modal-content plan-modal">
    <view class="modal-header">
      {{editingPlan ? '编辑计划' : '新建学习计划'}}
    </view>
    
    <view class="modal-body">
      <!-- 科目选择 -->
      <view class="form-group">
        <view class="form-label">科目 *</view>
        <picker mode="selector" range="{{subjects}}" value="{{formSubjectIndex}}" bindchange="onSubjectChange">
          <view class="form-picker">{{form.subject || '请选择科目'}} ▼</view>
        </picker>
      </view>

      <!-- 任务名称 -->
      <view class="form-group">
        <view class="form-label">任务名称 *</view>
        <input
          class="form-input"
          placeholder="例如：背诵古诗、做数学练习题..."
          value="{{form.title}}"
          bindinput="onTitleInput"
        />
      </view>

      <!-- 频率 -->
      <view class="form-group">
        <view class="form-label">频率</view>
        <picker mode="selector" range="{{frequencies}}" value="{{formFreqIndex}}" bindchange="onFrequencyChange">
          <view class="form-picker">{{form.frequency || '每天'}} ▼</view>
        </picker>
      </view>

      <!-- 自定义频率：星期多选 -->
      <view class="form-group" wx:if="{{showCustomWeekdays}}">
        <view class="form-label">选择日期</view>
        <view class="weekday-selector">
          <view 
            wx:for="{{weekdays}}" 
            wx:key="key"
            class="weekday-item {{customWeekdaySelected[index] ? 'weekday-selected' : ''}}"
            data-index="{{index}}"
            bindtap="toggleCustomWeekday"
          >{{item.shortName}}</view>
        </view>
        <view class="weekday-hint">点击选择每周执行日期，至少选择一天</view>
      </view>

      <!-- 目标次数 -->
      <view class="form-group">
        <view class="form-label">目标打卡次数</view>
        <input
          class="form-input"
          type="number"
          placeholder="例如：21（坚持21天养成习惯）"
          value="{{form.targetCount}}"
          bindinput="onTargetInput"
        />
        <view class="target-hint">累计完成该次数后，计划自动达成 🎯</view>
      </view>

      <!-- 备注 -->
      <view class="form-group">
        <view class="form-label">备注（可选）</view>
        <textarea
          class="form-textarea"
          placeholder="添加一些备注信息..."
          value="{{form.notes}}"
          bindinput="onNotesInput"
        ></textarea>
      </view>
    </view>

    <view class="modal-footer">
      <button class="cancel-btn" bindtap="hideAddModal">取消</button>
      <button class="confirm-btn {{saving ? 'btn-loading' : ''}}" bindtap="savePlan" disabled="{{saving}}">
        {{editingPlan ? '更新' : '创建'}}
      </button>
    </view>
  </view>
</view>
