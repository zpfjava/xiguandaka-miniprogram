/* 每日签到页样式 */
.dailycheckin-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
}

/* 顶部 */
.page-header {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 30rpx 30rpx 36rpx;
}
.header-title { font-size: 38rpx; font-weight: bold; color: #333333; }
.header-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-top: 8rpx; }

/* 签到卡片 */
.checkin-card {
  margin: -20rpx 30rpx 24rpx;
  padding: 48rpx 36rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFEF5 100%);
  border-radius: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 217, 61, 0.2);
}

.checkin-emoji { font-size: 80rpx; }
.checkin-text { font-size: 32rpx; color: #333333; margin-top: 16rpx; font-weight: bold; }
.checkin-reward { font-size: 28rpx; color: #FF9A3C; margin-top: 10rpx; }

.checkin-btn {
  width: 360rpx;
  height: 96rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #7ED957 0%, #4CAF50 100%);
  color: white !important;
  font-size: 34rpx;
  font-weight: bold;
  border-radius: 48rpx;
  text-align: center;
  border: none;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}
.checkin-btn::after { display: none !important; border: none; }
.checkin-btn:active { opacity: 0.85; transform: scale(0.97); }
.checkin-btn.disabled { opacity: 0.6; }

/* 已签到状态 */
.checked-emoji { font-size: 80rpx; animation: bounce-in 0.5s ease-out; }
.checked-text { font-size: 32rpx; color: #4CAF50; margin-top: 16rpx; font-weight: bold; }
.checked-reward { font-size: 28rpx; color: #4CAF50; margin-top: 10rpx; }
.checked-time { font-size: 24rpx; color: #999999; margin-top: 8rpx; }

.checked-btn {
  width: 360rpx;
  height: 96rpx;
  line-height: 1.2;
  background-color: #E8F5E9;
  color: #4CAF50 !important;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 48rpx;
  text-align: center;
  border: none;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
}
.checked-btn::after { display: none !important; border: none; }

@keyframes bounce-in {
  0% { transform: scale(0.3); opacity: 0; }
  60% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

/* 连续签到卡片 */
.streak-card {
  margin: 0 30rpx 24rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.streak-info {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.streak-icon { font-size: 44rpx; margin-right: 16rpx; }
.streak-detail { flex: 1; }
.streak-value { font-size: 30rpx; font-weight: bold; color: #333333; }
.streak-desc { font-size: 24rpx; color: #999999; margin-top: 6rpx; }

/* 里程碑 */
.milestones {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  border-top: 1rpx solid #F5F5F5;
}

.milestone-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.milestone-dot {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: bold;
  background-color: #F0F0F0;
  color: #999999;
  transition: all 0.3s ease;
}

.milestone-item.achieved .milestone-dot {
  background-color: #4CAF50;
  color: white;
  font-size: 26rpx;
}

.milestone-item.current .milestone-dot {
  background-color: #FFD93D;
  color: #333333;
  animation: pulse 2s infinite;
}

.milestone-day { font-size: 22rpx; color: #999999; margin-top: 6rpx; }
.milestone-bonus { font-size: 20rpx; color: #FF9A3C; font-weight: bold; }
.milestone-item.achieved .milestone-bonus { color: #4CAF50; }

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

/* 日历区域 */
.calendar-section {
  margin: 0 30rpx 24rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 20rpx; }

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.calendar-nav {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 36rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 12rpx;
}

.calendar-month { font-size: 30rpx; font-weight: bold; color: #333333; }

.calendar-weekdays {
  display: flex;
  margin-bottom: 10rpx;
}

.weekday {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 0;
}

.calendar-days {
  display: flex;
  flex-wrap: wrap;
}

.calendar-day {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 8rpx 0;
}

.day-number { font-size: 26rpx; color: #333333; }
.other-month .day-number { color: #CCCCCC; }
.today .day-number { 
  color: #FF9A3C; 
  font-weight: bold;
}
.today::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #FF9A3C;
}

.day-check {
  position: absolute;
  bottom: 2rpx;
  right: calc(50% - 18rpx);
  width: 24rpx;
  height: 24rpx;
  background-color: #4CAF50;
  color: white;
  font-size: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  line-height: 1;
}

/* 规则说明 */
.rules-section {
  margin: 0 30rpx 24rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rule-list { }
.rule-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
}
.rule-item:first-child { padding-top: 0; }

.rule-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #FFD93D;
  margin-right: 14rpx;
  margin-top: 10rpx;
  flex-shrink: 0;
}

.rule-text { font-size: 26rpx; color: #666666; line-height: 1.6; }
