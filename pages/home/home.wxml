<!-- 小打卡 - 首页 -->
<view class="home-page">
  <!-- 骨架屏：数据加载中显示，加载完成后隐藏 -->
  <block wx:if="{{_skeleton}}">
    <view class="home-skeleton">
      <!-- 问候区骨架 -->
      <view class="skeleton-header">
        <view class="skeleton-circle skeleton-avatar"></view>
        <view class="skeleton-lines">
          <view class="skeleton-line long"></view>
          <view class="skeleton-line medium"></view>
        </view>
      </view>
      <!-- 进度区骨架 -->
      <view class="skeleton-progress-row">
        <view class="skeleton-card skeleton-progress-card">
          <view class="skeleton-circle skeleton-ring"></view>
          <view class="skeleton-line short center"></view>
        </view>
        <view class="skeleton-card skeleton-stars-card">
          <view class="skeleton-line short center"></view>
          <view class="skeleton-line tiny center"></view>
        </view>
      </view>
      <!-- 快捷操作骨架 -->
      <view class="skeleton-actions-row">
        <view class="skeleton-card skeleton-action" wx:for="{{4}}" wx:key="*this">
          <view class="skeleton-circle small center"></view>
          <view class="skeleton-line tiny center"></view>
        </view>
      </view>
      <!-- 任务列表骨架 -->
      <view class="skeleton-section">
        <view class="skeleton-line medium"></view>
        <view class="skeleton-task" wx:for="{{3}}" wx:key="*this">
          <view class="skeleton-circle small"></view>
          <view class="skeleton-lines flex-1">
            <view class="skeleton-line long"></view>
            <view class="skeleton-line short"></view>
          </view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 正式内容：数据就绪后显示 -->
  <view wx:if="{{!_skeleton}}" class="home-content">

  <!-- ====== 游客模式（未登录时展示） ====== -->
  <block wx:if="{{!isLoggedIn}}">
  <view class="guest-banner">
    <view class="guest-banner-icon">🌱</view>
    <view class="guest-banner-text">
      <view class="guest-banner-title">{{greeting}}，欢迎来到成长习惯打卡助手！</view>
      <view class="guest-banner-desc">登录后开启你的习惯养成之旅</view>
    </view>
    <view class="guest-banner-btn" bindtap="goToLogin">去登录</view>
  </view>

  <view class="guest-features">
    <view class="guest-feature-item">
      <view class="guest-feature-icon">📚</view>
      <view class="guest-feature-text">制定学习计划</view>
    </view>
    <view class="guest-feature-item">
      <view class="guest-feature-icon">✅</view>
      <view class="guest-feature-text">每日签到打卡</view>
    </view>
    <view class="guest-feature-item">
      <view class="guest-feature-icon">⭐</view>
      <view class="guest-feature-text">积累星星奖励</view>
    </view>
    <view class="guest-feature-item">
      <view class="guest-feature-icon">🏆</view>
      <view class="guest-feature-text">解锁成长成就</view>
    </view>
  </view>
  </block>

  <!-- ====== 已登录内容（含个人数据，游客不可见） ====== -->
  <block wx:if="{{isLoggedIn}}">
  <!-- 顶部区域 - 问候 + 吉祥物 + 日期 -->
  <view class="home-header">
    <view class="greeting-row">
      <view class="greeting-left">
        <view class="mascot-mini">
          <mascot
            totalDays="{{stats.totalCheckins || 0}}"
            size="small"
            state="idle"
          />
        </view>
        <view class="greeting-text">
          <view class="greeting-hello">{{greeting}}，</view>
          <view class="greeting-name">{{userInfo.nickname || '小朋友'}}</view>
        </view>
      </view>
      <view class="date-badge">
        <text class="date-icon">📅</text>
        <text>{{todayDate}}</text>
      </view>
    </view>
  </view>

  <!-- 进度区域 - 进度环 + 星星卡片 -->
  <view class="progress-section">
    <!-- 左侧：进度环 -->
    <view class="progress-card">
      <view class="progress-card-title">今日完成</view>
      <view class="progress-ring-wrapper">
        <progress-ring
          progress="{{progressPercent}}"
          size="medium"
          label=""
        />
      </view>
      <view class="progress-ring-label">
        {{completedCount}}/{{totalCount}} 任务
      </view>
    </view>

    <!-- 右侧：星星卡片 -->
    <view class="stars-card-mini">
      <view class="stars-icon-big">⭐</view>
      <view class="stars-amount-big">{{stats.totalStars || userInfo.currentStars || 0}}</view>
      <view class="stars-label">我的星星</view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="quick-actions">
    <view class="action-btn" bindtap="goToPlans">
      <view class="action-icon">📚</view>
      <view class="action-label">学习计划</view>
    </view>
    <view class="action-btn" bindtap="goToDailyCheckin">
      <view class="action-icon">📅</view>
      <view class="action-label">每日签到</view>
    </view>
    <view class="action-btn" bindtap="goToStats">
      <view class="action-icon">📊</view>
      <view class="action-label">学习统计</view>
    </view>
    <view class="action-btn" bindtap="goToWishlist">
      <view class="action-icon">🎁</view>
      <view class="action-label">愿望清单</view>
    </view>
  </view>
  </block>

  <!-- 今日任务 -->
  <view class="section" bindlongpress="forceRefreshTasks">
    <view class="section-header">
      <view class="section-title">
        <text class="section-title-icon">📝</text>
        今日任务
      </view>
      <view class="section-subtitle">
        {{completedCount}}/{{totalCount}} 已完成
      </view>
    </view>

    <!-- 空状态 -->
    <block wx:if="{{todayTasks.length === 0}}">
      <!-- 未登录：游客模式空状态 -->
      <view class="guest-empty-state" wx:if="{{isEmpty}}">
        <view class="guest-empty-icon">🌱</view>
        <view class="guest-empty-title">{{emptyTip}}</view>
        <view class="guest-empty-desc">登录后开启习惯养成之旅，记录每一天的成长~</view>
        <view class="guest-login-btn" bindtap="goToLogin">
          <text class="guest-login-icon">🚀</text>
          <text>去登录</text>
        </view>
      </view>
      <!-- 已登录但无任务 -->
      <view class="empty-state" wx:else>
        <view class="empty-icon">📝</view>
        <view class="empty-text">今天还没有任务哦</view>
        <view class="add-task-btn" bindtap="goToPlans">添加任务</view>
      </view>
    </block>

    <!-- 任务列表 -->
    <block wx:else>
      <view class="task-list">
        <view
          wx:for="{{todayTasks}}"
          wx:key="_id"
          class="task-item {{item.isCompleted ? 'completed' : ''}}"
        >
          <view class="task-icon">{{item.subjectIcon}}</view>
          <view class="task-content">
            <view class="task-title">{{item.title}}</view>
            <view class="task-desc">{{item.subject}}</view>
          </view>
          <view class="task-right">
            <block wx:if="{{item.isCompleted === null}}">
              <view class="checkin-btn checkin-placeholder">···</view>
            </block>
            <block wx:elif="{{item.isCompleted}}">
              <view class="completed-badge">
                <text>✓</text>
              </view>
            </block>
            <block wx:else>
              <!-- 非打卡日（按频率判断） -->
              <block wx:if="{{item.isCheckinDay === false}}">
                <view class="checkin-btn rest-day-text">休息日</view>
              </block>
              <!-- 打卡日：显示去打卡 -->
              <block wx:else>
                <view
                  class="checkin-btn"
                  data-plan-id="{{item.id || item._id}}"
                  bindtap="goToCheckin"
                >去打卡</view>
              </block>
            </block>
          </view>
        </view>
      </view>
    </block>
  </view>

  <!-- 统计数据（仅已登录时显示） -->
  <block wx:if="{{isLoggedIn}}">
  <view class="section">
    <view class="section-header">
      <view class="section-title">
        <text class="section-title-icon">📊</text>
        我的统计
      </view>
    </view>
    <view class="stats-grid">
      <view class="stat-card">
        <view class="stat-icon">📋</view>
        <view class="stat-value">{{stats.totalPlans || 0}}</view>
        <view class="stat-label">总计划</view>
      </view>
      <view class="stat-card">
        <view class="stat-icon">✅</view>
        <view class="stat-value">{{stats.totalCheckins || 0}}</view>
        <view class="stat-label">打卡次数</view>
      </view>
      <view class="stat-card">
        <view class="stat-icon">⭐</view>
        <view class="stat-value">{{stats.totalStars || userInfo.currentStars || 0}}</view>
        <view class="stat-label">累计星星</view>
      </view>
    </view>
  </view>
  </block>

  <!-- 底部小贴士 -->
  <view class="tips-section">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-title">{{encouragement.title}}</view>
      <view class="tips-text">{{encouragement.text}}</view>
    </view>
  </view>
</view>
</view>
