/* 首页样式 */
.home-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background-color: #FFF8E1;
}

/* ====== 骨架屏（数据加载中显示） ====== */
.home-skeleton {
  padding: 0 30rpx;
}

.skeleton-header {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.skeleton-progress-row {
  display: flex;
  gap: 20rpx;
  padding: 0 10rpx;
}

.skeleton-progress-card, .skeleton-stars-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
}

.skeleton-progress-card { flex: 1.2; }
.skeleton-stars-card { flex: 0.8; }

.skeleton-ring { width: 160rpx; height: 160rpx; margin-bottom: 16rpx; }

.skeleton-actions-row {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 10rpx 0;
}

.skeleton-action {
  flex: 1;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.skeleton-section {
  margin: 24rpx 0 0;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 20rpx;
}

.skeleton-task {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.skeleton-task:last-child { border-bottom: none; }

/* 骨架屏通用元素 */
.skeleton-circle {
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
}
.skeleton-circle.small { width: 56rpx; height: 56rpx; }

.skeleton-line {
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
  margin-bottom: 12rpx;
}
.skeleton-line.long { width: 60%; }
.skeleton-line.medium { width: 40%; }
.skeleton-line.short { width: 25%; }
.skeleton-line.tiny { width: 15%; }
.skeleton-line::after { content: ''; display: block; margin-bottom: 0; }

.skeleton-lines { display: flex; flex-direction: column; }
.skeleton-lines.flex-1 { flex: 1; margin-left: 20rpx; }

.skeleton-card {
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.skeleton-line.center { margin-left: auto; margin-right: auto; }
.skeleton-circle.center { margin-left: auto; margin-right: auto; }
.skeleton-circle.small.center { margin: 0; }

@keyframes skeleton-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ====== 顶部区域 ====== */
.home-header {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 30rpx 30rpx 36rpx;
}

.greeting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.greeting-left {
  display: flex;
  align-items: center;
}

.mascot-mini {
  margin-right: 16rpx;
}

.greeting-hello {
  font-size: 30rpx;
  color: rgba(51, 51, 51, 0.7);
}

.greeting-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #333333;
}

.date-badge {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.9);
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #666666;
}

.date-icon { margin-right: 8rpx; }

/* ====== 进度区域 ====== */
.progress-section {
  display: flex;
  padding: 30rpx;
  gap: 20rpx;
}

.progress-card {
  flex: 1.2;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  overflow: hidden; /* 防止内容溢出 */
}

.progress-card-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.progress-ring-wrapper {
  /* 固定尺寸容器，防止 canvas 重绘时抖动 */
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progress-ring-label {
  font-size: 26rpx;
  color: #666666;
  margin-top: 10rpx;
  font-weight: bold;
}

.stars-card-mini {
  flex: 0.8;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  border-radius: 24rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 60, 0.2);
}

.stars-icon-big { font-size: 48rpx; }
.stars-amount-big { 
  font-size: 52rpx; 
  font-weight: bold; 
  color: #333333; 
  margin: 8rpx 0 4rpx; 
}
.stars-label { 
  font-size: 22rpx; 
  color: rgba(51, 51, 51, 0.7); 
}

/* ====== 快捷操作 ====== */
.quick-actions {
  display: flex;
  padding: 0 30rpx;
  gap: 16rpx;
  margin: 24rpx 0;
}

.action-btn {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-btn:active { transform: scale(0.96); }

.action-icon { font-size: 44rpx; margin-bottom: 10rpx; }
.action-label { font-size: 22rpx; color: #666666; }

/* ====== 区域通用 ====== */
.section {
  margin: 0 30rpx 24rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* ====== 任务列表 ====== */
.task-list { padding: 0 20rpx; }

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.task-item:last-child { border-bottom: none; }
.task-item.completed { opacity: 0.6; }

.task-icon {
  font-size: 48rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E1;
  border-radius: 16rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.task-content { flex: 1; }
.task-title { font-size: 30rpx; color: #333333; font-weight: 500; }
.task-desc { font-size: 24rpx; color: #999999; margin-top: 6rpx; }

.task-right { margin-left: 16rpx; flex-shrink: 0; }

.completed-badge {
  width: 56rpx;
  height: 56rpx;
  background-color: #7ED957;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.checkin-btn {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 24rpx;
  font-weight: bold;
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
}
.checkin-btn:active { opacity: 0.85; }

/* 加载中占位 */
.checkin-placeholder {
  background: transparent;
  color: #CCCCCC;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
  border-radius: 9999rpx;
}

/* 非打卡日（休息日） */
.rest-day-text {
  background-color: #F5F5F5;
  color: #BBBBBB;
  font-size: 22rpx;
  padding: 14rpx 20rpx;
  border-radius: 9999rpx;
}

/* ====== 统计卡片 ====== */
.stats-grid {
  display: flex;
  padding: 24rpx 16rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
}

.stat-icon { font-size: 40rpx; margin-bottom: 10rpx; }
.stat-value { 
  font-size: 38rpx; 
  font-weight: bold; 
  color: #333333; 
}
.stat-label { 
  font-size: 22rpx; 
  color: #999999; 
  margin-top: 6rpx; 
}

/* ====== 游客模式横幅（未登录首页顶部） ====== */
.guest-banner {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 32rpx 30rpx;
  margin-bottom: 20rpx;
  border-radius: 24rpx;
}

.guest-banner-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.guest-banner-text {
  flex: 1;
}

.guest-banner-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.guest-banner-desc {
  font-size: 24rpx;
  color: rgba(51, 51, 51, 0.7);
}

.guest-banner-btn {
  background-color: #333333;
  color: #FFD93D;
  font-size: 26rpx;
  font-weight: bold;
  padding: 14rpx 36rpx;
  border-radius: 9999rpx;
  flex-shrink: 0;
}
.guest-banner-btn:active { opacity: 0.85; }

/* ====== 游客功能介绍卡片 ====== */
.guest-features {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
}

.guest-feature-item {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.guest-feature-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.guest-feature-text {
  font-size: 26rpx;
  color: #555555;
  font-weight: 500;
}

/* ====== 游客模式空状态（任务区域，未登录时展示） ====== */
.guest-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 40rpx;
}

.guest-empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  animation: guest-bounce 2s ease-in-out infinite;
}

@keyframes guest-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.guest-empty-title {
  font-size: 32rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.guest-empty-desc {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.guest-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
  padding: 22rpx 64rpx;
  border-radius: 9999rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 154, 60, 0.3);
}

.guest-login-btn:active {
  opacity: 0.85;
  transform: scale(0.96);
}

.guest-login-icon { font-size: 32rpx; }

/* ====== 已登录空状态（无任务时展示） ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
}

.empty-icon { font-size: 96rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 30rpx; color: #666666; margin-bottom: 16rpx; }

.add-task-btn {
  background: linear-gradient(135deg, #7ED957 0%, #5BC030 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  padding: 18rpx 48rpx;
  border-radius: 9999rpx;
  box-shadow: 0 4rpx 16rpx rgba(126, 217, 87, 0.3);
}
.add-task-btn:active { opacity: 0.85; transform: scale(0.96); }

/* ====== 底部小贴士 ====== */
.tips-section {
  display: flex;
  align-items: flex-start;
  margin: 24rpx 30rpx;
  padding: 24rpx;
  background-color: #FFFDE7;
  border-radius: 16rpx;
}

.tips-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.tips-content { flex: 1; }
.tips-title { font-size: 26rpx; font-weight: bold; color: #333333; }
.tips-text { font-size: 24rpx; color: #666666; margin-top: 6rpx; line-height: 1.5; }
