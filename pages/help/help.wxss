/* 帮助与反馈页样式 */
.help-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
}

/* 顶部 */
.page-header {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 30rpx 30rpx 36rpx;
}
.header-title { font-size: 38rpx; font-weight: bold; color: #333333; }
.header-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-top: 8rpx; }

/* 区域卡片 */
.section-card {
  margin: 20rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.section-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 20rpx; }

/* FAQ 列表 */
.faq-list { }

.faq-item {
  border-bottom: 1rpx solid #F5F5F5;
}
.faq-item:last-child { border-bottom: none; }

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
}
.faq-question:active { opacity: 0.7; }

.faq-q-text { 
  flex: 1; 
  font-size: 28rpx; 
  color: #333333; 
  font-weight: 500; 
  padding-right: 16rpx; 
}
.faq-arrow { 
  font-size: 34rpx; 
  color: #CCCCCC; 
  transition: transform 0.3s ease; 
  flex-shrink: 0;
}
.faq-arrow.expanded { transform: rotate(90deg); }

.faq-answer {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
  padding: 0 0 18rpx 16rpx;
  border-left: 4rpx solid #FFD93D;
  animation: slideDown 0.3s ease;
}

@keyframes slideDown {
  from { opacity: 0; max-height: 0; }
  to { opacity: 1; max-height: 500rpx; }
}

/* 新手指南 */
.guide-steps { }
.guide-step {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.guide-step:last-child { border-bottom: none; }

.step-number {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 26rpx;
  font-weight: bold;
  border-radius: 50%;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.step-content { flex: 1; }
.step-title { font-size: 28rpx; color: #333333; font-weight: 500; }
.step-desc { font-size: 24rpx; color: #999999; margin-top: 6rpx; line-height: 1.5; }

/* 反馈表单 */
.form-group { margin-bottom: 22rpx; }
.form-label { font-size: 28rpx; font-weight: bold; color: #333333; margin-bottom: 12rpx; display: block; }

.type-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.type-item {
  padding: 12rpx 24rpx;
  font-size: 25rpx;
  color: #666666;
  background-color: #F5F5F5;
  border-radius: 9999rpx;
  border: 2rpx solid transparent;
}
.type-item.active {
  color: #FF9A3C;
  background-color: #FFF8E1;
  border-color: #FFD93D;
  font-weight: bold;
}

.feedback-input {
  width: 100%;
  min-height: 180rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  line-height: 1.7;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 8rpx;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  text-align: center;
  border: none;
  margin-top: 10rpx;
}
.submit-btn::after { border: none; }
.submit-btn:active { opacity: 0.85; }
.submit-btn.disabled { opacity: 0.6; }
.submit-btn.btn-loading { opacity: 0.6; }

/* 联系我们 */
.contact-section {
  margin: 20rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.contact-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 18rpx; }

.contact-list { }
.contact-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.contact-item:last-child { border-bottom: none; }
.contact-item:active { opacity: 0.8; }

.contact-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.contact-info { flex: 1; }
.contact-name { font-size: 27rpx; color: #333333; }
.contact-detail { font-size: 23rpx; color: #999999; margin-top: 4rpx; }
.contact-action {
  font-size: 24rpx;
  color: #FF9A3C;
  padding: 6rpx 18rpx;
  background-color: #FFF8E1;
  border-radius: 9999rpx;
  flex-shrink: 0;
}

/* 版本信息 */
.version-info {
  text-align: center;
  font-size: 22rpx;
  color: #BBBBBB;
  padding: 30rpx 0 20rpx;
}
