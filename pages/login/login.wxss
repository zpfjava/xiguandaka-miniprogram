/* 登录页样式 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Logo 区域 */
.login-header {
  margin-top: 120rpx;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s ease-in-out infinite;
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 表单区域 */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(255, 217, 61, 0.15);
}

/* 切换标签 */
.form-tabs {
  display: flex;
  border-radius: 16rpx;
  background-color: #F5F5F5;
  padding: 6rpx;
  margin-bottom: 36rpx;
}

.form-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  color: #999999;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.form-tabs .tab.active {
  background-color: #FFD93D;
  color: #333333;
  font-weight: bold;
}

/* 输入框容器 */
.form-fields {
  margin-bottom: 36rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

/* 微信小程序不支持 :focus-within，使用 focus 类替代 */

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
}

.form-select {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
  display: flex;
  align-items: center;
}

/* 提交按钮 */
.submit-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333 !important;
  font-size: 34rpx !important;
  font-weight: bold;
  border-radius: 48rpx !important;
  text-align: center;
  border: none !important;
  padding: 0 !important;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  overflow: visible;
}

.submit-btn::after {
  display: none !important;
}

.submit-btn.disabled {
  opacity: 0.6;
}

.submit-btn.active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 演示模式 */
.demo-mode {
  text-align: center;
  margin-top: 30rpx;
}

.demo-mode text {
  font-size: 26rpx;
  color: #FF9A3C;
}

/* 底部说明 */
.login-footer {
  margin-top: auto;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #BBBBBB;
  text-align: center;
  line-height: 1.6;
}

.footer-text .link {
  color: #FF9A3C;
}

/* 吉祥物装饰 */
.mascot-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  animation: float 3s ease-in-out infinite;
}

.mascot-text {
  font-size: 60rpx;
  margin-right: 12rpx;
}

.mascot-bubble {
  font-size: 22rpx;
  color: #FF9A3C;
  background-color: #FFF8E1;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #FFECB3;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
