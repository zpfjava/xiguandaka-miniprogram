/* 登录页样式（支持三种登录方式） */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF8E1 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
}

/* Logo 区域 */
.login-header {
  margin-top: 100rpx;
  margin-bottom: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  animation: bounce 2s ease-in-out infinite;
}

.app-name {
  font-size: 52rpx;
  font-weight: bold;
  color: #333333;
  letter-spacing: 4rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* ==================== 微信一键登录区域 ==================== */
.wx-login-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.wx-login-btn {
  width: 100% !important;
  height: 96rpx !important;
  line-height: 1.2 !important;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%) !important;
  color: #FFFFFF !important;
  font-size: 34rpx !important;
  font-weight: bold;
  border-radius: 48rpx !important;
  text-align: center;
  border: none !important;
  padding: 0 !important;
  display: flex !important;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.wx-login-btn::after {
  display: none !important;
}

.wx-login-btn .wx-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.wx-login-btn.disabled {
  opacity: 0.6;
}
.wx-login-btn[disabled] { opacity: 0.6; }

.wx-silent-login {
  padding: 16rpx 0;
}

.wx-silent-login text {
  font-size: 26rpx;
  color: #999999;
}

.other-login-entry {
  margin-top: 40rpx;
  padding: 20rpx 0;
}

.other-login-entry text {
  font-size: 26rpx;
  color: #BBBBBB;
}

/* ==================== 表单区域 ==================== */
.login-form {
  width: 100%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 40rpx rgba(255, 217, 61, 0.15);
}

.back-wx {
  text-align: center;
  margin-bottom: 24rpx;
}

.back-wx text {
  font-size: 26rpx;
  color: #07C160;
}

.back-wx .back-arrow {
  font-size: 28rpx;
}

/* 切换标签 */
.form-tabs {
  display: flex;
  border-radius: 16rpx;
  background-color: #F5F5F5;
  padding: 6rpx;
  margin-bottom: 36rpx;
}

.form-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  color: #999999;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.form-tabs .tab.active {
  background-color: #FFD93D;
  color: #333333;
  font-weight: bold;
}

/* 输入框容器 */
.form-fields {
  margin-bottom: 36rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  margin-bottom: 24rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.3s;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
}

.form-select {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  height: 100%;
  display: flex;
  align-items: center;
}

/* 短信验证码输入 */
.sms-code-item .code-input {
  flex: 1;
}

.send-code-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #FF9A3C;
  padding: 12rpx 20rpx;
  border: 2rpx solid #FF9A3C;
  border-radius: 24rpx;
  margin-left: 16rpx;
  white-space: nowrap;
}

.send-code-btn.disabled {
  color: #CCCCCC;
  border-color: #EEEEEE;
}

/* 提交按钮 */
.submit-btn {
  width: 100% !important;
  height: 96rpx;
  line-height: 1.2;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333 !important;
  font-size: 34rpx !important;
  font-weight: bold;
  border-radius: 48rpx !important;
  text-align: center;
  border: none !important;
  padding: 0 !important;
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.submit-btn::after {
  display: none !important;
}

.submit-btn.disabled {
  opacity: 0.6;
}
.submit-btn.btn-loading { opacity: 0.6; }

.register-btn {
  margin-top: 10rpx;
}

.register-fields {
  margin-top: 20rpx;
  margin-bottom: 20rpx;
}

/* 表单额外操作 */
.form-extra {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 24rpx;
  font-size: 26rpx;
}

.form-extra .link {
  color: #FF9A3C;
  padding: 0 8rpx;
}

.form-extra .divider {
  color: #DDDDDD;
}

/* ==================== 注册弹窗（Modal）==================== */
.register-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  transition: opacity 0.25s ease;
}

.register-modal {
  position: fixed;
  bottom: -100%;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  padding: 40rpx 36rpx 60rpx;
  max-height: 85vh;
  overflow-y: auto;
  transition: bottom 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.12);
}

.register-modal.show {
  bottom: 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999999;
  border-radius: 50%;
  background-color: #F5F5F5;
}

.modal-body {
  margin-bottom: 24rpx;
}

.modal-footer {
  text-align: center;
}

.reg-submit-btn {
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.reg-tip {
  font-size: 24rpx;
  color: #FF9A3C;
}

/* 演示模式 */
.demo-mode {
  text-align: center;
  margin-top: 30rpx;
}

.demo-mode text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部说明 */
.login-footer {
  margin-top: auto;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #BBBBBB;
  text-align: center;
  line-height: 1.6;
}

.footer-text .link {
  color: #FF9A3C;
}

/* 吉祥物装饰 */
.mascot-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 30rpx;
  animation: float 3s ease-in-out infinite;
}

.mascot-text {
  font-size: 60rpx;
  margin-right: 12rpx;
}

.mascot-bubble {
  font-size: 22rpx;
  color: #FF9A3C;
  background-color: #FFF8E1;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1px solid #FFECB3;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
