<!-- 小打卡 - 登录页（支持三种登录方式） -->
<view class="login-page">

  <!-- 返回按钮（允许用户取消登录，返回浏览） -->
  <view class="back-nav" bindtap="goBack">
    <text class="back-nav-text">← 返回</text>
  </view>

  <!-- ==================== 隐私政策弹窗 ==================== -->
  <view class="privacy-mask" wx:if="{{showPrivacyModal}}" catchtouchmove="preventMove">
    <view class="privacy-modal">
      <view class="privacy-header">
        <text class="privacy-title">隐私政策</text>
      </view>

      <scroll-view class="privacy-body" scroll-y="true">
        <view class="privacy-content">
          <view class="privacy-section">
            <view class="privacy-section-title">一、我们收集的信息</view>
            <view class="privacy-text">
              为提供打卡服务，我们需要收集以下信息：
            </view>
            <view class="privacy-text">• 手机号码：用于账号注册和身份验证</view>
            <view class="privacy-text">• 昵称、头像：用于个性化展示</view>
            <view class="privacy-text">• 学习计划、打卡记录：用于核心功能服务</view>
            <view class="privacy-text">• 设备信息：用于保障服务安全稳定运行</view>
          </view>

          <view class="privacy-section">
            <view class="privacy-section-title">二、信息使用范围</view>
            <view class="privacy-text">
              您提供的个人信息将仅用于以下用途：
            </view>
            <view class="privacy-text">• 创建和管理您的学习打卡账户</view>
            <view class="privacy-text">• 提供学习计划管理、打卡签到等核心功能</view>
            <view class="privacy-text">• 生成个人学习统计和报告</view>
            <view class="privacy-text">• 改善和优化产品体验</view>
          </view>

          <view class="privacy-section">
            <view class="privacy-section-title">三、信息保护</view>
            <view class="privacy-text">
              我们采取业界标准的安全措施保护您的个人信息，包括数据加密存储、访问控制等技术手段。我们不会向任何第三方出售或共享您的个人信息。
            </view>
          </view>

          <view class="privacy-section">
            <view class="privacy-section-title">四、用户权利</view>
            <view class="privacy-text">
              您有权访问、更正、删除您的个人信息。如需相关操作，请通过设置页面中的"导出我的数据"功能，或联系客服处理。
            </view>
          </view>

          <view class="privacy-section">
            <view class="privacy-section-title">五、未成年人保护</view>
            <view class="privacy-text">
              我们非常重视未成年人个人信息保护。若您是未成年人，请在监护人的陪同下阅读本政策，并在取得监护人同意后使用我们的服务。
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="privacy-footer">
        <button class="privacy-btn privacy-disagree-btn" bindtap="disagreePrivacy">不同意</button>
        <button class="privacy-btn privacy-agree-btn" bindtap="agreePrivacy">同意并继续</button>
      </view>
    </view>
  </view>
  <!-- Logo 区域 -->
  <view class="login-header">
    <view class="logo">🌱</view>
    <view class="app-name">成长习惯打卡助手</view>
    <view class="app-slogan">让好习惯伴你成长</view>
  </view>

  <!-- 微信一键登录（推荐） -->
  <view class="wx-login-section" wx:if="{{!showOtherLogin}}">
    <button
      class="wx-login-btn {{wxLoggingIn ? 'disabled' : ''}}"
      open-type="getPhoneNumber"
      bindgetphonenumber="onGetWxPhoneNumber"
      disabled="{{wxLoggingIn}}"
    >
      <text class="wx-icon">💬</text>
      <text>微信一键登录</text>
    </button>

    <view class="wx-silent-login" bindtap="handleWxSilentLogin">
      <text>仅微信登录（不绑定手机号）</text>
    </view>

    <!-- 其他登录方式入口 -->
    <view class="other-login-entry" bindtap="toggleOtherLogin">
      <text>其他登录方式 ▼</text>
    </view>
  </view>

  <!-- 其他登录方式（短信 / 密码） -->
  <view class="login-form" wx:if="{{showOtherLogin}}">
    <!-- 返回微信登录 -->
    <view class="back-wx" bindtap="toggleOtherLogin">
      <text class="back-arrow">← </text>
      <text>返回微信登录</text>
    </view>

    <!-- 切换标签：暂时仅保留密码登录（短信功能待签名审核通过后开启） -->
    <!-- <view class="form-tabs">
      <view
        class="tab {{loginMode === 'sms' ? 'active' : ''}}"
        bindtap="switchLoginMode"
        data-mode="sms"
      >短信登录</view>
      <view
        class="tab {{loginMode === 'password' ? 'active' : ''}}"
        bindtap="switchLoginMode"
        data-mode="password"
      >密码登录</view>
    </view> -->

    <!-- ========== 统一表单区域 ========== -->
    <view class="form-fields">
      <!-- 手机号 -->
      <view class="form-item">
        <view class="input-icon">📱</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          maxlength="11"
          value="{{form.phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <!-- 短信验证码（仅短信模式） -->
      <block wx:if="{{loginMode === 'sms'}}">
        <view class="form-item sms-code-item">
          <view class="input-icon">🔑</view>
          <input
            class="form-input code-input"
            type="number"
            placeholder="请输入验证码"
            maxlength="6"
            value="{{form.smsCode}}"
            bindinput="onSmsCodeInput"
          />
          <view
            class="send-code-btn {{smsCooldown > 0 || !form.phone ? 'disabled' : ''}}"
            bindtap="sendSmsCode"
          >
            {{smsCooldown > 0 ? smsCooldown + 's后重发' : '获取验证码'}}
          </view>
        </view>
      </block>

      <!-- 密码（仅密码模式） -->
      <block wx:if="{{loginMode === 'password'}}">
        <view class="form-item">
          <view class="input-icon">🔒</view>
          <input
            class="form-input"
            type="text"
            password="{{true}}"
            placeholder="请输入密码（至少6位）"
            value="{{form.password}}"
            bindinput="onPasswordInput"
          />
        </view>
      </block>
    </view>

    <!-- 提交按钮 -->
    <button
      class="submit-btn {{loading ? 'disabled' : ''}}"
      bindtap="handleSubmit"
      disabled="{{loading}}"
    >
      {{loginMode === 'sms' ? '登 录' : '登 录'}}
    </button>

    <!-- 密码模式下的辅助操作 -->
    <view class="form-extra" wx:if="{{loginMode === 'password'}}">
      <text class="link" bindtap="showRegisterModal">注册新账号</text>
      <text class="divider">|</text>
      <!-- 短信登录入口（待签名审核通过后取消注释） -->
      <!-- <text class="link" bindtap="switchToSmsLogin">用验证码登录</text> -->
    </view>

    <!-- 开发环境演示入口（上线后已隐藏，需要时取消注释） -->
    <!-- <view class="demo-mode" wx:if="{{isDev}}">
      <text bindtap="handleDemoLogin">开发模式：跳过登录 →</text>
    </view> -->
  </view>

  <!-- ==================== 注册弹窗（Modal）==================== -->
  <view class="register-mask" wx:if="{{showRegisterModal}}" bindtap="hideRegisterModal"></view>
  <view class="register-modal {{showRegisterModal ? 'show' : ''}}" catchtouchmove="preventMove">
    <view class="modal-header">
      <text class="modal-title">注册新账号</text>
      <view class="modal-close" bindtap="hideRegisterModal">✕</view>
    </view>

    <view class="modal-body">
      <!-- 手机号 -->
      <view class="form-item">
        <view class="input-icon">📱</view>
        <input
          class="form-input"
          type="number"
          placeholder="请输入手机号"
          maxlength="11"
          value="{{regForm.phone}}"
          bindinput="onRegPhoneInput"
        />
      </view>

      <!-- 密码 -->
      <view class="form-item">
        <view class="input-icon">🔒</view>
        <input
          class="form-input"
          type="text"
          password="{{true}}"
          placeholder="设置密码（至少6位）"
          value="{{regForm.password}}"
          bindinput="onRegPasswordInput"
        />
      </view>

      <!-- 确认密码 -->
      <view class="form-item">
        <view class="input-icon">🔒</view>
        <input
          class="form-input"
          type="text"
          password="{{true}}"
          placeholder="确认密码"
          value="{{regForm.confirmPassword}}"
          bindinput="onRegConfirmPwdInput"
        />
      </view>

      <!-- 昵称（可选） -->
      <view class="form-item">
        <view class="input-icon">👤</view>
        <input
          class="form-input"
          type="text"
          placeholder="昵称（可选）"
          value="{{regForm.nickname}}"
          bindinput="onRegNicknameInput"
        />
      </view>

      <!-- 年级选择 -->
      <view class="form-item">
        <view class="input-icon">📚</view>
        <picker mode="selector" range="{{grades}}" value="{{regGradeIndex}}" bindchange="onRegGradeChange">
          <view class="form-select">{{regForm.grade || '请选择年级'}} ▼</view>
        </picker>
      </view>
    </view>

    <view class="modal-footer">
      <!-- 注册弹窗内的协议勾选 -->
      <view class="reg-agreement-row" bindtap="toggleRegAgreementCheck">
        <view class="checkbox-wrap {{regAgreementChecked ? 'checked' : ''}}">
          <text wx:if="{{regAgreementChecked}}" class="check-icon">✓</text>
        </view>
        <view class="reg-agreement-text">
          我已阅读并同意
          <text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text>
        </view>
      </view>
      <button
        class="submit-btn reg-submit-btn {{regLoading ? 'disabled' : ''}}"
        bindtap="handleRegisterFromModal"
        disabled="{{regLoading}}"
      >
        {{regLoading ? '注 册' : '注 册'}}
      </button>
      <view class="reg-tip">注册即赠送 50 颗星星 ⭐</view>
    </view>
  </view>

  <!-- 底部协议勾选 -->
  <view class="login-footer">
    <view class="agreement-row" bindtap="toggleAgreementCheck">
      <view class="checkbox-wrap {{agreementChecked ? 'checked' : ''}}">
        <text wx:if="{{agreementChecked}}" class="check-icon">✓</text>
      </view>
      <view class="agreement-text">
        我已阅读并同意
        <text class="link">《用户协议》</text>和<text class="link">《隐私政策》</text>
      </view>
    </view>
  </view>

  <!-- 吉祥物装饰 -->
  <view class="mascot-decoration">
    <view class="mascot-text">🌱</view>
    <view class="mascot-bubble">注册送50星星哦~</view>
  </view>
</view>
