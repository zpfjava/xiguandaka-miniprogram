/* 家长绑定页样式 */
.parent-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
}

/* 顶部 */
.page-header {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  padding: 30rpx 30rpx 36rpx;
}
.header-title { font-size: 38rpx; font-weight: bold; color: #333333; }
.header-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-top: 8rpx; }

/* 未绑定卡片 */
.bind-card {
  margin: 20rpx 30rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bind-emoji { font-size: 72rpx; text-align: center; }
.bind-title { 
  text-align: center; 
  font-size: 34rpx; 
  font-weight: bold; 
  color: #333333; 
  margin-top: 16rpx; 
}
.bind-desc { 
  text-align: center; 
  font-size: 26rpx; 
  color: #666666; 
  margin-top: 10rpx; 
}

.feature-list { margin-top: 24rpx; }

.feature-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.feature-item:last-child { border-bottom: none; }

.feature-icon { font-size: 36rpx; margin-right: 16rpx; flex-shrink: 0; }
.feature-text { font-size: 27rpx; color: #555555; line-height: 1.4; }

/* 绑定方式 */
.bind-methods { margin-top: 28rpx; }
.method-title { font-size: 28rpx; font-weight: bold; color: #333333; margin-bottom: 16rpx; }

.method-btn {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 24rpx;
  background-color: #FAFAFA;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  margin-bottom: 14rpx;
  text-align: left;
}
.method-btn::after { border: none; }
.method-btn:active { background-color: #F5F5F5; border-color: #FFECB3; }

.method-icon { font-size: 44rpx; margin-right: 18rpx; flex-shrink: 0; }
.method-info { flex: 1; }
.method-name { font-size: 29rpx; color: #333333; font-weight: 500; }
.method-desc { font-size: 23rpx; color: #999999; margin-top: 4rpx; }
.method-arrow { font-size: 36rpx; color: #CCCCCC; flex-shrink: 0; }

/* 已绑定卡片 */
.bound-card {
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.parent-avatar {
  width: 96rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 48rpx;
  background-color: #FFF8E1;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.parent-info { flex: 1; }
.parent-name { font-size: 32rpx; font-weight: bold; color: #333333; }
.parent-phone { font-size: 26rpx; color: #999999; margin-top: 4rpx; }
.bind-time { font-size: 22rpx; color: #BBBBBB; margin-top: 4rpx; }

.unbind-btn {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  background-color: #FFEBEE;
  color: #F44336;
  font-size: 24rpx;
  border-radius: 32rpx;
  border: none;
  flex-shrink: 0;
}
.unbind-btn::after { border: none; }
.unbind-btn:active { opacity: 0.7; }

/* 区域卡片 */
.section-card {
  margin: 20rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.section-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 20rpx; }

/* 设置列表 */
.setting-list { }
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.setting-item:last-child { border-bottom: none; }

.setting-left { flex: 1; }
.setting-label { font-size: 29rpx; color: #333333; }
.setting-desc { font-size: 23rpx; color: #BBBBBB; margin-top: 4rpx; }

/* 留言区域 */
.message-input {
  width: 100%;
  min-height: 140rpx;
  font-size: 28rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
}

.send-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 42rpx;
  text-align: center;
  border: none;
}
.send-btn::after { border: none; }
.send-btn:active { opacity: 0.85; }

/* 安全提示 */
.security-tip {
  display: flex;
  align-items: flex-start;
  margin: 24rpx 30rpx;
  padding: 20rpx;
  background-color: #E8F5E9;
  border-radius: 16rpx;
}
.tip-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.tip-content { flex: 1; }
.tip-title { font-size: 26rpx; font-weight: bold; color: #2E7D32; }
.tip-text { font-size: 23rpx; color: #558B2F; margin-top: 4rpx; line-height: 1.5; }

/* 弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.5); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
}

.bind-modal {
  width: 580rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  padding: 30rpx;
  text-align: center;
  font-size: 33rpx;
  font-weight: bold;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-body { padding: 30rpx; }

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.bind-note {
  font-size: 24rpx;
  color: #999999;
  margin-top: 16rpx;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-footer button {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  font-size: 30rpx;
  background: none;
  border: none;
}
.modal-footer button::after { border: none; }
.cancel-btn { color: #999999; border-right: 1rpx solid #F0F0F0 !important; }
.confirm-btn { color: #FF9A3C; font-weight: bold; }
.confirm-btn[disabled] { color: #CCCCCC; }
