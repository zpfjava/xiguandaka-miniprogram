<!-- 小打卡 - 设置页 -->
<view class="settings-page {{settings.darkMode ? 'dark-mode' : ''}}">
  <!-- 个人信息编辑区 -->
  <view class="profile-section">
    <view class="profile-header">
      <view class="profile-avatar" hover-class="avatar-hover" bindtap="changeAvatar">
        <image
          wx:if="{{userInfo.avatar && userInfo.avatar !== '😊'}}"
          src="{{userInfo.avatar}}"
          class="avatar-image"
          mode="aspectFill"
        />
        <text wx:else>😊</text>
      </view>
      
      <view class="profile-edit">
        <view class="input-wrap">
          <input
            class="nickname-input {{nicknameError ? 'input-error' : ''}}"
            placeholder="输入昵称"
            value="{{userInfo.nickname}}"
            bindinput="onNicknameInput"
          />
          <view wx:if="{{nicknameError}}" class="field-error">{{nicknameError}}</view>
        </view>
        <view class="input-wrap">
          <picker mode="selector" range="{{grades}}" value="{{gradeIndex}}" bindchange="onGradeChange">
            <view class="grade-picker {{gradeError ? 'picker-error' : ''}}">{{userInfo.grade || '选择年级'}} ▼</view>
          </picker>
          <view wx:if="{{gradeError}}" class="field-error">{{gradeError}}</view>
        </view>
      </view>
    </view>
    
    <!-- 保存按钮 -->
    <view class="save-area">
      <button 
        class="save-profile-btn {{!hasChanges ? 'btn-idle' : ''}}" 
        bindtap="saveProfile"
        disabled="{{saving || !hasChanges}}"
      >保存修改</button>
      <!-- 仅错误时显示提示 -->
      <view wx:if="{{saveStatus === 'error'}}" class="save-tip save-tip-error">
        <text>{{saveMsg}}</text>
      </view>
    </view>
  </view>


  <!-- 设置分组 - 数据管理 -->
  <view class="setting-group">
    <view class="group-title">数据管理</view>

    <view class="setting-item" bindtap="exportData">
      <view class="item-left">
        <text class="item-icon">📤</text>
        <text class="item-text">导出我的数据</text>
      </view>
      <text class="item-arrow">›</text>
      <text class="item-hint">JSON 格式</text>
    </view>

    <view class="setting-item" bindtap="exportReport">
      <view class="item-left">
        <text class="item-icon">📋</text>
        <text class="item-text">导出学习报告</text>
      </view>
      <text class="item-arrow">›</text>
      <text class="item-hint">本周数据</text>
    </view>

    <view class="setting-item" bindtap="clearCache">
      <view class="item-left">
        <text class="item-icon">🗑️</text>
        <text class="item-text">清除缓存</text>
      </view>
      <text class="item-arrow">{{cacheSize}} ›</text>
    </view>
  </view>

  <!-- 设置分组 - 隐私 -->
  <view class="setting-group">
    <view class="group-title">隐私与安全</view>

    <view class="setting-item" bindtap="goToPrivacy">
      <view class="item-left">
        <text class="item-icon">🔒</text>
        <text class="item-text">隐私设置</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- 设置分组 - 关于 -->
  <view class="setting-group">
    <view class="group-title">关于</view>

    <view class="setting-item">
      <view class="item-left">
        <text class="item-icon">📱</text>
        <text class="item-text">版本号</text>
      </view>
      <text class="item-value">v1.0.0</text>
    </view>

    <view class="setting-item" bindtap="checkUpdate">
      <view class="item-left">
        <text class="item-icon">🔄</text>
        <text class="item-text">检查更新</text>
      </view>
      <text class="item-arrow">›</text>
    </view>

    <view class="setting-item" bindtap="showAbout">
      <view class="item-left">
        <text class="item-icon">ℹ️</text>
        <text class="item-text">关于成长习惯打卡助手</text>
      </view>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info">
    <view class="footer-logo">🌱 成长习惯打卡助手</view>
    <view class="footer-desc">让好习惯伴你成长</view>
    <view class="footer-version">Version 1.0.0 · Build 20260423</view>
  </view>
</view>
