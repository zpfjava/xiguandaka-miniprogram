/* 设置页样式 */
.settings-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
  transition: background-color 0.3s ease;
}

/* 深色模式 */
.settings-page.dark-mode {
  background-color: #1a1a1a;
}
.dark-mode .profile-section { background-color: #2a2a2a; }
.dark-mode .setting-group { background-color: #2a2a2a; }
.dark-mode .group-title { color: #888888; }
.dark-mode .setting-item { border-bottom-color: #333333; }
.dark-mode .item-text { color: #e0e0e0; }
.dark-mode .item-desc { color: #888888; }
.dark-mode .nickname-input { background-color: #333333; color: #e0e0e0; }
.dark-mode .nickname-input.input-error { background-color: #3a2222; border-color: #FF4D4F; }
.dark-mode .grade-picker { background-color: #333333; color: #cccccc; }
.dark-mode .grade-picker.picker-error { background-color: #3a2222; border-color: #FF4D4F; }
.dark-mode .footer-logo { color: #e0e0e0; }
.dark-mode .footer-desc { color: #888888; }
.dark-mode .footer-version { color: #666666; }

/* 个人信息区 */
.profile-section {
  background-color: #FFFFFF;
  padding: 32rpx 30rpx;
}

.profile-header {
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  background-color: #FFF8E1;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  position: relative;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
}

.profile-edit { flex: 1; }

.input-wrap {
  margin-bottom: 8rpx;
}

.nickname-input {
  width: 100%;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}
.nickname-input:focus { border-color: #FFD93D; }

/* 输入框错误态 */
.nickname-input.input-error {
  border-color: #FF4D4F;
  background-color: #FFF1F0;
}

.grade-picker {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #F8F8F8;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}
.grade-picker.picker-error {
  border-color: #FF4D4F;
  background-color: #FFF1F0;
  color: #FF4D4F;
}

/* 字段错误提示 */
.field-error {
  font-size: 22rpx;
  color: #FF4D4F;
  padding: 4rpx 0 0 8rpx;
}

/* 保存区域 */
.save-area {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.save-profile-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  text-align: center;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
.save-profile-btn::after { border: none; }
.save-profile-btn:active { opacity: 0.85; }

/* 未变更时按钮置灰 */
.save-profile-btn.btn-idle {
  background: #CCCCCC;
  color: #999999;
}
.save-profile-btn.btn-idle:active { opacity: 1; }

/* 保存中状态 */
.save-profile-btn.saving {
  background: linear-gradient(135deg, #FFB347 0%, #FF8C00 100%);
  opacity: 0.9;
}

/* 加载旋转动画 */
.btn-loading {
  display: inline-block;
  animation: rotate 1s linear infinite;
  font-size: 28rpx;
}
@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 内联状态提示 */
.save-tip {
  margin-top: 16rpx;
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  animation: fadeInUp 0.3s ease-out;
}
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.tip-icon { margin-right: 8rpx; }

.save-tip-success {
  background-color: #F0FFF0;
  color: #52C41A;
}

.save-tip-error {
  background-color: #FFF2F0;
  color: #FF4D4F;
}

/* 设置分组 */
.setting-group {
  margin-top: 20rpx;
  background-color: #FFFFFF;
}

.group-title {
  padding: 18rpx 30rpx 10rpx;
  font-size: 24rpx;
  color: #999999;
  font-weight: bold;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.setting-item:last-child { border-bottom: none; }
.setting-item:active { background-color: #FAFAFA; }

.item-left { display: flex; align-items: center; }
.item-icon { font-size: 34rpx; margin-right: 14rpx; width: 40rpx; text-align: center; }
.item-text { font-size: 29rpx; color: #333333; }
.item-text-wrap { display: flex; flex-direction: column; }
.item-desc { font-size: 22rpx; color: #BBBBBB; margin-top: 2rpx; }

.item-arrow {
  font-size: 30rpx;
  color: #CCCCCC;
}

.item-value {
  font-size: 27rpx;
  color: #999999;
}

.item-hint {
  font-size: 23rpx;
  color: #BBBBBB;
  margin-right: 8rpx;
}

/* 底部信息 */
.footer-info {
  padding: 60rpx 30rpx 30rpx;
  text-align: center;
}

.footer-logo { 
  font-size: 36rpx; 
  font-weight: bold; 
  color: #333333; 
  margin-bottom: 6rpx; 
}
.footer-desc { 
  font-size: 24rpx; 
  color: #BBBBBB; 
  margin-bottom: 10rpx; 
}
.footer-version { 
  font-size: 20rpx; 
  color: #DDDDDD; 
}
