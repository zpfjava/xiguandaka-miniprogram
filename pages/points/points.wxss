/* 积分页样式 */
.points-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
  overflow-x: hidden;
}

/* ====== 骨架屏 ====== */
.points-skeleton { padding: 0 30rpx; }

.skeleton-stars-card {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.skeleton-star-icon {
  width: 72rpx; height: 72rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
}

.skeleton-count {
  width: 120rpx !important;
  height: 88rpx !important;
  border-radius: 16rpx;
  margin: 16rpx auto 8rpx;
}

.skeleton-actions-row {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-top: 30rpx;
}
.skeleton-actions-row .skeleton-line {
  width: 160rpx !important;
  height: 72rpx !important;
  border-radius: 36rpx;
  margin: 0;
}

.skeleton-section-card {
  margin: 0 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
}

.skeleton-way {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.skeleton-way:last-child { border-bottom: none; }

/* 骨架屏通用元素（复用 shimmer 动画） */
.skeleton-circle {
  border-radius: 50%;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
  flex-shrink: 0;
}
.skeleton-circle.small { width: 56rpx; height: 56rpx; }

.skeleton-line {
  height: 32rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s infinite;
  margin-bottom: 12rpx;
}
.skeleton-line.long { width: 60%; }
.skeleton-line.medium { width: 40%; }
.skeleton-line.short { width: 25%; }
.skeleton-line.tiny { width: 15%; }
.skeleton-line::after { content: ''; display: block; margin-bottom: 0; }

.skeleton-lines { display: flex; flex-direction: column; }
.skeleton-lines.flex-1 { flex: 1; margin-left: 18rpx; }

.skeleton-line.center, .skeleton-circle.center { margin-left: auto; margin-right: auto; }

@keyframes skeleton-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ====== 星星卡片 ====== */
.stars-card {
  padding: 30rpx;
}

.stars-bg {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 154, 60, 0.25);
}

.stars-emoji { font-size: 72rpx; }
.stars-label { font-size: 28rpx; color: rgba(51, 51, 51, 0.7); margin-top: 12rpx; }

.stars-count { 
  font-size: 88rpx; 
  font-weight: bold; 
  color: #333333; 
  margin: 16rpx 0 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 217, 61, 0.4);
}

.stars-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-bottom: 30rpx; }

.stars-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.stars-actions .action-btn {
  padding: 18rpx 36rpx;
  height: 72rpx;
  line-height: 36rpx;
  background-color: rgba(255, 255, 255, 0.95);
  color: #333333;
  font-size: 26rpx;
  border-radius: 36rpx;
  text-align: center;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.stars-actions .action-btn::after { border: none; }
.stars-actions .action-btn:active { opacity: 0.85; transform: scale(0.96); }

/* ====== 区域卡片 ====== */
.section-card {
  margin: 24rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 24rpx; }

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-header-row .section-title { margin-bottom: 0; }
.section-more { font-size: 24rpx; color: #FF9A3C; }

/* ====== 获取方式列表 ====== */
.ways-list { }

.way-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.way-item:last-child { border-bottom: none; }

.way-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E1;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.way-content { flex: 1; }
.way-name { font-size: 28rpx; color: #333333; font-weight: 500; }
.way-desc { font-size: 22rpx; color: #999999; margin-top: 4rpx; }

.way-reward {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9A3C;
  background-color: #FFF8E1;
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
}

/* ====== 积分记录 ====== */
.records-list { }

.record-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.record-item:last-child { border-bottom: none; }

.record-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.record-icon.earn { background-color: #E8F5E9; color: #4CAF50; }
.record-icon.spend { background-color: #FFEBEE; color: #F44336; }

.record-info { flex: 1; }
.record-desc { font-size: 27rpx; color: #333333; }
.record-time { font-size: 22rpx; color: #CCCCCC; margin-top: 4rpx; }

.record-amount { font-size: 30rpx; font-weight: bold; }
.earn-text { color: #4CAF50; }
.spend-text { color: #F44336; }

/* 空状态 */
.empty-tip {
  margin: 40rpx 30rpx;
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

/* 游客模式空状态（更大的留白和提示） */
.empty-tip.guest-empty {
  margin-top: 120rpx;
  padding: 60rpx 30rpx;
}

.empty-tip .empty-text-desc {
  font-size: 24rpx;
  color: #BBBBBB;
  margin-bottom: 32rpx;
  display: block;
}

.empty-tip .empty-icon-large {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-tip .empty-text-large {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 24rpx;
  display: block;
}

.empty-tip .empty-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  color: #333333;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

/* 底部提示 */
.tips-section {
  display: flex;
  align-items: flex-start;
  margin: 24rpx 30rpx;
  padding: 24rpx;
  background-color: #FFFDE7;
  border-radius: 16rpx;
}
.tips-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.tips-content { flex: 1; }
.tips-text { font-size: 24rpx; color: #666666; line-height: 1.5; }
