/* 积分页样式 */
.points-page {
  min-height: 100vh;
  background-color: #FFF8E1;
  padding-bottom: 40rpx;
}

/* ====== 星星卡片 ====== */
.stars-card {
  padding: 30rpx;
}

.stars-bg {
  background: linear-gradient(135deg, #FFD93D 0%, #FF9A3C 100%);
  border-radius: 32rpx;
  padding: 48rpx 36rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 154, 60, 0.25);
}

.stars-emoji { font-size: 72rpx; }
.stars-label { font-size: 28rpx; color: rgba(51, 51, 51, 0.7); margin-top: 12rpx; }

.stars-count { 
  font-size: 88rpx; 
  font-weight: bold; 
  color: #333333; 
  margin: 16rpx 0 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(255, 217, 61, 0.4);
}

.stars-subtitle { font-size: 26rpx; color: rgba(51, 51, 51, 0.6); margin-bottom: 30rpx; }

.stars-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.stars-actions .action-btn {
  padding: 0 32rpx;
  background-color: rgba(255, 255, 255, 0.95);
  color: #333333;
  font-size: 26rpx;
  border-radius: 34rpx;
  text-align: center;
  border: none;
}
.stars-actions .action-btn::after { border: none; }
.stars-actions .action-btn:active { opacity: 0.85; transform: scale(0.96); }

/* ====== 区域卡片 ====== */
.section-card {
  margin: 24rpx 30rpx;
  padding: 28rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title { font-size: 32rpx; font-weight: bold; color: #333333; margin-bottom: 24rpx; }

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-header-row .section-title { margin-bottom: 0; }
.section-more { font-size: 24rpx; color: #FF9A3C; }

/* ====== 获取方式列表 ====== */
.ways-list { }

.way-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.way-item:last-child { border-bottom: none; }

.way-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFF8E1;
  border-radius: 16rpx;
  font-size: 32rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.way-content { flex: 1; }
.way-name { font-size: 28rpx; color: #333333; font-weight: 500; }
.way-desc { font-size: 22rpx; color: #999999; margin-top: 4rpx; }

.way-reward {
  font-size: 28rpx;
  font-weight: bold;
  color: #FF9A3C;
  background-color: #FFF8E1;
  padding: 6rpx 16rpx;
  border-radius: 9999rpx;
}

/* ====== 积分记录 ====== */
.records-list { }

.record-item {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.record-item:last-child { border-bottom: none; }

.record-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.record-icon.earn { background-color: #E8F5E9; color: #4CAF50; }
.record-icon.spend { background-color: #FFEBEE; color: #F44336; }

.record-info { flex: 1; }
.record-desc { font-size: 27rpx; color: #333333; }
.record-time { font-size: 22rpx; color: #CCCCCC; margin-top: 4rpx; }

.record-amount { font-size: 30rpx; font-weight: bold; }
.earn-text { color: #4CAF50; }
.spend-text { color: #F44336; }

/* 空状态 */
.empty-tip {
  margin: 40rpx 30rpx;
  padding: 30rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

/* 底部提示 */
.tips-section {
  display: flex;
  align-items: flex-start;
  margin: 24rpx 30rpx;
  padding: 24rpx;
  background-color: #FFFDE7;
  border-radius: 16rpx;
}
.tips-icon { font-size: 32rpx; margin-right: 12rpx; flex-shrink: 0; }
.tips-content { flex: 1; }
.tips-text { font-size: 24rpx; color: #666666; line-height: 1.5; }
