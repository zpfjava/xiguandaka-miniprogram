<!-- 小打卡 - 积分（星星）页 -->
<view class="points-page">
  <!-- 骨架屏：数据加载中显示 -->
  <block wx:if="{{_skeleton}}">
    <view class="points-skeleton">
      <!-- 星星卡片骨架 -->
      <view class="skeleton-stars-card">
        <view class="skeleton-circle skeleton-star-icon center"></view>
        <view class="skeleton-line tiny center"></view>
        <view class="skeleton-line skeleton-count center"></view>
        <view class="skeleton-line short center"></view>
        <view class="skeleton-actions-row">
          <view class="skeleton-line medium"></view>
          <view class="skeleton-line medium"></view>
        </view>
      </view>
      <!-- 获取方式骨架 -->
      <view class="skeleton-section-card">
        <view class="skeleton-line medium"></view>
        <view class="skeleton-way" wx:for="{{4}}" wx:key="*this">
          <view class="skeleton-circle small"></view>
          <view class="skeleton-lines flex-1">
            <view class="skeleton-line long"></view>
            <view class="skeleton-line short"></view>
          </view>
          <view class="skeleton-line short"></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 正式内容：数据就绪后显示 -->
  <block wx:if="{{!_skeleton}}">
  <!-- 星星卡片 -->
  <view class="stars-card">
    <view class="stars-bg">
      <view class="stars-emoji">⭐</view>
      <view class="stars-label">我的星星</view>
      <view class="stars-count">{{summary ? (summary.currentStars || 0) : ''}}</view>
      <view class="stars-subtitle">累计获得 {{summary ? (summary.totalEarned || 0) : ''}} 颗</view>
      
      <!-- 快捷操作 -->
      <view class="stars-actions">
        <button class="action-btn" bindtap="goToHistory">
          📜 积分明细
        </button>
        <button class="action-btn" bindtap="goToWishlist">
          🎁 兑换奖励
        </button>
      </view>
    </view>
  </view>

  <!-- 获取星星的方式 -->
  <view class="section-card">
    <view class="section-title">🌟 如何获取星星？</view>
    
    <view class="ways-list">
      <view class="way-item">
        <view class="way-icon">✅</view>
        <view class="way-content">
          <view class="way-name">完成学习打卡</view>
          <view class="way-desc">每次打卡获得该计划设定的星星奖励</view>
        </view>
        <view class="way-reward">+5</view>
      </view>
      
      <view class="way-item">
        <view class="way-icon">📅</view>
        <view class="way-content">
          <view class="way-name">每日签到</view>
          <view class="way-desc">连续签到天数越多，奖励越丰厚</view>
        </view>
        <view class="way-reward">+5~20</view>
      </view>
      
      <view class="way-item">
        <view class="way-icon">🏆</view>
        <view class="way-content">
          <view class="way-name">解锁成就</view>
          <view class="way-desc">达成特定目标可获得大量星星奖励</view>
        </view>
        <view class="way-reward">+10~200</view>
      </view>

      <view class="way-item">
        <view class="way-icon">💰</view>
        <view class="way-content">
          <view class="way-name">系统奖励</view>
          <view class="way-desc">管理员可发放额外星星奖励</view>
        </view>
        <view class="way-reward">不定</view>
      </view>
    </view>
  </view>

  <!-- 最近积分记录 -->
  <view class="section-card" wx:if="{{recentRecords.length > 0}}">
    <view class="section-header-row">
      <view class="section-title">📊 最近记录</view>
      <view class="section-more" bindtap="goToHistory">查看全部 →</view>
    </view>
    
    <view class="records-list">
      <view 
        wx:for="{{recentRecords}}" 
        wx:key="id"
        class="record-item"
      >
        <view class="record-icon {{item.type === 'earn' ? 'earn' : 'spend'}}">
          {{item.type === 'earn' ? '+' : '-'}}
        </view>
        <view class="record-info">
          <view class="record-desc">{{item.description}}</view>
          <view class="record-time">{{item.time}}</view>
        </view>
        <view class="record-amount {{item.type === 'earn' ? 'earn-text' : 'spend-text'}}">
          {{item.amount > 0 ? '+' : ''}}{{item.amount}} ⭐
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态提示：只有星星数为0且无记录时才显示 -->
  <view class="empty-tip" wx:if="{{(summary && summary.currentStars || 0) === 0 && recentRecords.length === 0}}">
    <text>还没有积分记录哦，快去打卡赚取第一颗星星吧！🌟</text>
  </view>

  <!-- 底部说明 -->
  <view class="tips-section">
    <view class="tips-icon">💡</view>
    <view class="tips-content">
      <view class="tips-text">星星可以用来兑换愿望清单中的奖励哦！去"我的"页面添加你的愿望吧~</view>
    </view>
  </view>
  </block>
</view>
