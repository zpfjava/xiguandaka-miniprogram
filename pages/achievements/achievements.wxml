<!-- 小打卡 - 成就页 -->
<view class="achievements-page">
  <!-- 顶部 -->
  <view class="page-header">
    <view class="header-title">🏆 我的成就</view>
    <view class="header-subtitle">记录你的每一个里程碑</view>
  </view>

  <!-- 成就概览 -->
  <view class="overview-card">
    <view class="overview-item">
      <view class="overview-value">{{unlockedCount}}</view>
      <view class="overview-label">已解锁</view>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <view class="overview-value">{{totalCount}}</view>
      <view class="overview-label">总成就</view>
    </view>
    <view class="overview-divider"></view>
    <view class="overview-item">
      <view class="overview-value">{{progressPercent}}%</view>
      <view class="overview-label">完成度</view>
    </view>
  </view>

  <!-- 骨架屏（加载中占位） -->
  <block wx:if="{{loading}}">
    <view class="section-title-bar">
      <text class="shimmer" style="width:180rpx;height:32rpx;border-radius:8rpx;display:inline-block"></text>
    </view>

    <view class="achievement-list">
      <view class="achievement-card skeleton-card" wx:for="{{[1,2,3,4]}}" wx:key="*this">
        <view class="shimmer skeleton-icon"></view>
        <view class="skeleton-info">
          <view class="shimmer" style="width:55%;height:30rpx;border-radius:8rpx;margin-bottom:12rpx"></view>
          <view class="shimmer" style="width:80%;height:22rpx;border-radius:6rpx;margin-bottom:14rpx"></view>
          <view class="shimmer" style="width:45%;height:18rpx;border-radius:6rpx"></view>
        </view>
        <view class="skeleton-reward">
          <view class="shimmer" style="width:80rpx;height:36rpx;border-radius:18rpx;margin-bottom:10rpx"></view>
          <view class="shimmer" style="width:70rpx;height:32rpx;border-radius:16rpx"></view>
        </view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && isEmpty}}">
    <text class="empty-icon">🏆</text>
    <text class="empty-title">还没有成就数据</text>
    <text class="empty-desc">快去完成学习打卡，解锁你的第一个成就吧！</text>
  </view>

  <!-- 成就列表 -->
  <block wx:if="{{!loading && !isEmpty}}">
    <view class="section-title-bar">
      <text>🎖️ 全部成就</text>
    </view>

    <view class="achievement-list">
      <view
        wx:for="{{achievements}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onAchievementTap"
        class="achievement-card {{item.unlocked ? 'unlocked' : 'locked'}}"
      >
        <view class="achievement-icon {{item.unlocked ? '' : 'gray'}}">
          {{item.emoji || item.icon || '🏆'}}
        </view>

        <view class="achievement-info">
          <view class="achievement-name">{{item.name}}</view>
          <view class="achievement-desc">{{item.description}}</view>

          <!-- 进度（未解锁时显示） -->
          <block wx:if="{{!item.unlocked && item.target > 0}}">
            <view class="achievement-progress">
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
              </view>
              <view class="progress-text">{{item.current}}/{{item.target}}</view>
            </view>
          </block>

          <!-- 解锁时间（已解锁时显示） -->
          <block wx:if="{{item.unlocked}}">
            <view class="unlock-time">✅ 已解锁</view>
          </block>
        </view>

        <view class="achievement-reward">
          <view class="reward-badge {{item.unlocked ? 'earned' : ''}}">
            +{{item.reward || item.starsReward || 0}} ⭐
          </view>
          <view class="status-badge {{item.unlocked ? 'done' : 'todo'}}">
            {{item.unlocked ? '已获得' : '未解锁'}}
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
