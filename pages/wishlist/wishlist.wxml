<!-- 小打卡 - 愿望清单页 -->
<view class="wishlist-page">
  <!-- 顶部 -->
  <view class="page-header">
    <view class="header-title">🎁 我的愿望清单</view>
    <view class="header-subtitle">用星星兑换你的心愿</view>
  </view>

  <!-- 星星余额 -->
  <view class="balance-card">
    <view class="balance-label">可用星星</view>
    <view class="balance-amount">{{currentStars}} ⭐</view>
    <button class="add-wish-btn" bindtap="showAddModal">+ 新增愿望</button>
  </view>

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view 
      class="tab {{activeTab === 'all' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="all"
    >全部 ({{totalCount}})</view>
    <view 
      class="tab {{activeTab === 'pending' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="pending"
    >待兑换 ({{pendingCount}})</view>
    <view 
      class="tab {{activeTab === 'redeemed' ? 'active' : ''}}"
      bindtap="switchTab"
      data-tab="redeemed"
    >已兑换 ({{redeemedCount}})</view>
  </view>

  <!-- 愿望列表 -->
  <block wx:if="{{filteredWishes.length > 0}}">
    <view class="wish-list">
      <view 
        wx:for="{{filteredWishes}}" 
        wx:key="_id"
        class="wish-card {{item.status === 'redeemed' ? 'redeemed' : ''}}"
      >
        <view class="wish-emoji">{{item.emoji || '🎁'}}</view>
        
        <view class="wish-info">
          <view class="wish-name">{{item.title}}</view>
          <view class="wish-desc" wx:if="{{item.description}}">{{item.description}}</view>
          
          <!-- 进度条（待兑换状态） -->
          <block wx:if="{{item.status !== 'redeemed'}}">
            <view class="wish-progress">
              <view class="progress-bar">
                <view class="progress-fill" style="width: {{item.progressPercent}}%"></view>
              </view>
              <view class="progress-text">
                已存 {{item.savedStars}} / {{item.costStars}} ⭐
              </view>
            </view>
          </block>
          
          <!-- 已兑换标记 -->
          <block wx:if="{{item.status === 'redeemed'}}">
            <view class="redeemed-badge">✅ 已于 {{item.redeemedDate || '2026-04-20'}} 兑换</view>
          </block>
        </view>

        <view class="wish-actions">
          <!-- 待兑换：操作按钮 -->
          <block wx:if="{{item.status === 'pending'}}">
            <button 
              class="action-btn save-btn"
              data-id="{{item.id || item._id}}"
              bindtap="saveStars"
              wx:if="{{item.canSave}}"
            >存入⭐</button>
            
            <button 
              class="action-btn redeem-btn {{!item.canRedeem ? 'disabled' : ''}}"
              data-item="{{item}}"
              bindtap="redeemWish"
              disabled="{{!item.canRedeem}}"
            >兑换</button>
          </block>
        </view>

        <!-- 删除按钮 -->
        <view 
          class="delete-wish"
          data-id="{{item.id || item._id}}"
          catchtap="deleteWish"
        >×</view>
      </view>
    </view>
  </block>

  <!-- 空状态 -->
  <block wx:else>
    <view class="empty-state">
      <view class="empty-icon">🎁</view>
      <view class="empty-text">
        {{activeTab === 'redeemed' ? '还没有兑换过愿望哦' : '愿望清单空空的'}}
      </view>
      <view class="empty-desc" wx:if="{{activeTab !== 'redeemed'}}">
        添加你的第一个愿望，用学习赚来的星星来兑换吧！
      </view>
    </view>
  </block>
</view>

<!-- 新增愿望弹窗 -->
<view class="modal-overlay" wx:if="{{showAddModal}}" catchtouchmove="preventMove">
  <view class="modal-content wish-modal">
    <view class="modal-header">新增愿望</view>
    
    <view class="modal-body">
      <!-- 表情选择 -->
      <view class="form-group">
        <view class="form-label">选择图标</view>
        <view class="emoji-picker">
          <view 
            wx:for="{{emojis}}" 
            wx:key="*this"
            class="emoji-option {{form.emoji === item ? 'selected' : ''}}"
            bindtap="selectEmoji"
            data-emoji="{{item}}"
          >{{item}}</view>
        </view>
      </view>

      <!-- 愿望名称 -->
      <view class="form-group">
        <view class="form-label">愿望名称 *</view>
        <input
          class="form-input"
          placeholder="例如：冰淇淋、新玩具、去游乐园..."
          value="{{form.title}}"
          bindinput="onTitleInput"
        />
      </view>

      <!-- 所需星星数 -->
      <view class="form-group">
        <view class="form-label">需要多少颗星星？*</view>
        <view class="star-input-area">
          <view class="star-minus" bindtap="decreaseStars">−</view>
          <input
            class="star-number-input"
            type="number"
            value="{{form.costStars}}"
            bindinput="onCostInput"
          />
          <view class="star-plus" bindtap="increaseStars">+</view>
          <text class="star-unit">⭐</text>
        </view>
      </view>

      <!-- 描述 -->
      <view class="form-group">
        <view class="form-label">描述（可选）</view>
        <textarea
          class="form-textarea"
          placeholder="描述一下这个愿望..."
          value="{{form.description}}"
          bindinput="onDescInput"
        ></textarea>
      </view>
    </view>

    <view class="modal-footer">
      <button class="cancel-btn" bindtap="hideAddModal">取消</button>
      <button class="confirm-btn {{saving ? 'btn-loading' : ''}}" bindtap="saveWish" disabled="{{saving}}">
        创建愿望
      </button>
    </view>
  </view>
</view>

<!-- 存入星星弹窗 -->
<view class="modal-overlay" wx:if="{{showSaveModal}}" catchtouchmove="preventMove">
  <view class="modal-content save-modal">
    <view class="save-modal-header">
      <text class="save-modal-title">⭐ 存入星星</text>
      <view class="save-modal-close" bindtap="hideSaveModal">×</view>
    </view>

    <view class="save-modal-body">
      <!-- 愿望信息 -->
      <view class="save-wish-info">
        <view class="save-wish-name">{{saveModal.wishTitle}}</view>
        <view class="save-progress-row">
          <text>已存 {{saveModal.savedStars}} / {{saveModal.costStars}} ⭐</text>
          <text class="save-remaining">还差 {{saveModal.remaining}} ⭐</text>
        </view>
        <view class="save-progress-bar">
          <view class="save-progress-fill" style="width: {{saveModal.costStars > 0 ? (saveModal.savedStars / saveModal.costStars * 100) : 0}}%"></view>
        </view>
      </view>

      <!-- 可用星星提示 -->
      <view class="save-balance-tip">
        可用星星：<text class="save-balance-num">{{saveModal.currentStars}}</text> ⭐
      </view>

      <!-- 快捷档位 -->
      <view class="save-quick-section">
        <view class="save-section-label">选择数量</view>
        <view class="save-quick-btns">
          <view
            wx:if="{{saveModal.maxSave >= 5}}"
            class="save-quick-btn {{saveModal.selectedAmount === 5 ? 'active' : ''}} {{saveModal.maxSave < 5 ? 'disabled' : ''}}"
            bindtap="selectSaveAmount"
            data-amount="5"
          >5 ⭐</view>
          <view
            wx:if="{{saveModal.maxSave >= 10}}"
            class="save-quick-btn {{saveModal.selectedAmount === 10 ? 'active' : ''}} {{saveModal.maxSave < 10 ? 'disabled' : ''}}"
            bindtap="selectSaveAmount"
            data-amount="10"
          >10 ⭐</view>
          <view
            wx:if="{{saveModal.maxSave >= 20}}"
            class="save-quick-btn {{saveModal.selectedAmount === 20 ? 'active' : ''}} {{saveModal.maxSave < 20 ? 'disabled' : ''}}"
            bindtap="selectSaveAmount"
            data-amount="20"
          >20 ⭐</view>
          <!-- 一键存满（仅当可用星星足够时显示） -->
          <view
            wx:if="{{saveModal.currentStars >= saveModal.remaining}}"
            class="save-quick-btn fill-all-btn {{saveModal.selectedAmount === saveModal.remaining ? 'active' : ''}}"
            bindtap="fillAllStars"
          >存满 {{saveModal.remaining}} ⭐</view>
          <!-- 全部存入（当星星不足时显示） -->
          <view
            wx:elif="{{saveModal.maxSave > 0}}"
            class="save-quick-btn fill-all-btn {{saveModal.selectedAmount === saveModal.maxSave ? 'active' : ''}}"
            bindtap="selectSaveAmount"
            data-amount="{{saveModal.maxSave}}"
          >全部 {{saveModal.maxSave}} ⭐</view>
        </view>
      </view>

      <!-- 自定义输入 -->
      <view class="save-custom-section">
        <view class="save-section-label">或自定义数量</view>
        <view class="save-custom-input-wrap">
          <input
            class="save-custom-input"
            type="number"
            value="{{saveModal.selectedAmount}}"
            bindinput="onCustomSaveInput"
            placeholder="输入数量"
          />
          <text class="save-custom-unit">⭐</text>
        </view>
        <view class="save-max-tip">最多可存入 {{saveModal.maxSave}} ⭐</view>
      </view>
    </view>

    <view class="save-modal-footer">
      <button class="save-cancel-btn" bindtap="hideSaveModal">取消</button>
      <button class="save-confirm-btn" bindtap="confirmSaveStars">
        确认存入 {{saveModal.selectedAmount || 0}} ⭐
      </button>
    </view>
  </view>
</view>
