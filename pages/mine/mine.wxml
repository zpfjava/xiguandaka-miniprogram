<!-- 小打卡 - 我的页面 -->
<view class="mine-page">

  <!-- 未登录游客状态 -->
  <block wx:if="{{!isLoggedIn || isEmpty}}">
    <view class="guest-state">
      <view class="guest-avatar">😊</view>
      <view class="guest-text">登录后查看个人信息</view>
      <view class="guest-btn" bindtap="goToLogin">去登录</view>
    </view>

    <!-- 游览版功能菜单（部分功能无需登录也可预览） -->
    <view class="menu-section">
      <view class="menu-group">
        <view class="menu-item" bindtap="goToHelp">
          <view class="menu-icon">❓</view>
          <view class="menu-text">帮助与反馈</view>
          <view class="menu-arrow">›</view>
        </view>
      </view>
    </view>

    <view class="version-info">成长习惯打卡助手 v1.0.0 · 让好习惯伴你成长 🌱</view>
  </block>

  <!-- 已登录状态 -->
  <block wx:else>
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar">
      <image
        wx:if="{{userInfo.avatar && userInfo.avatar !== '😊'}}"
        src="{{userInfo.avatar}}"
        class="avatar-image"
        mode="aspectFill"
      />
      <text wx:else>😊</text>
    </view>
    <view class="user-info">
      <view class="user-name">{{userInfo.nickname || '小朋友'}}</view>
      <view class="user-grade">{{userInfo.grade || '小学三年级'}}</view>
    </view>
    
    <!-- 编辑按钮 -->
    <button class="edit-btn" bindtap="goToSettings">
      ✏️ 编辑
    </button>
  </view>

  <!-- 成长数据 -->
  <view class="growth-section">
    <mascot 
      totalDays="{{stats.totalCheckins || 0}}" 
      size="medium"
      state="{{growthState}}"
    />
    <view class="growth-info">
      <view class="stage-name">{{stageName}}</view>
      <view class="stage-desc">{{stageDesc}}</view>
      <view class="streak-info" wx:if="{{stats.streak > 0}}">
        🔥 已连续打卡 {{stats.streak}} 天
      </view>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="data-overview">
    <view class="data-item">
      <view class="data-value">{{stats.totalPlans || 0}}</view>
      <view class="data-label">学习计划</view>
    </view>
    <view class="data-divider"></view>
    <view class="data-item">
      <view class="data-value">{{stats.totalCheckins || 0}}</view>
      <view class="data-label">累计打卡</view>
    </view>
    <view class="data-divider"></view>
    <view class="data-item">
      <view class="data-value">{{stats.streakDays || stats.streak || 0}}</view>
      <view class="data-label">连续天数</view>
    </view>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToWishlist">
        <view class="menu-icon">🎁</view>
        <view class="menu-text">愿望清单</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goToDailyCheckin">
        <view class="menu-icon">📅</view>
        <view class="menu-text">每日签到</view>
        <view class="menu-badge" wx:if="{{!dailyCheckedIn}}">未签</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goToAchievements">
        <view class="menu-icon">🏆</view>
        <view class="menu-text">我的成就</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToStats">
        <view class="menu-icon">📊</view>
        <view class="menu-text">学习统计</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goToReport">
        <view class="menu-icon">📈</view>
        <view class="menu-text">学习报告</view>
        <view class="menu-arrow">›</view>
      </view>

      <!-- 排行榜功能暂未开放 -->
      <!-- <view class="menu-item" bindtap="goToLeaderboard">
        <view class="menu-icon">🏅</view>
        <view class="menu-text">排行榜</view>
        <view class="menu-arrow">›</view>
      </view> -->
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToParent">
        <view class="menu-icon">👨‍👩‍👧</view>
        <view class="menu-text">家长绑定</view>
        <view class="menu-badge coming-soon">待开发</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goToHelp">
        <view class="menu-icon">❓</view>
        <view class="menu-text">帮助与反馈</view>
        <view class="menu-arrow">›</view>
      </view>

      <view class="menu-item" bindtap="goToSettings">
        <view class="menu-icon">⚙️</view>
        <view class="menu-text">设置</view>
        <view class="menu-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-area">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">成长习惯打卡助手 v1.0.0 · 让好习惯伴你成长 🌱</view>
  </block>
</view>
