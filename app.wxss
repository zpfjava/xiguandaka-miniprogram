/* page */
page{background-color:#FFF8E1;color:#333;font-family:-apple-system,BlinkMacSystemFont,sans-serif;font-size:15px;line-height:1.6;min-height:100%;overflow-x:hidden}
.page-container{min-height:100vh;padding-bottom:120rpx;background-color:#FFF8E1}
.page-header{padding:30rpx 30rpx 20px;background:linear-gradient(135deg,#FFD93D 0%,#FF9A3C 100%)}
.page-title{font-size:44rpx;font-weight:bold;color:#333}.page-subtitle{font-size:26rpx;color:#666;margin-top:6rpx}
.card{background:#FFF;border-radius:24rpx;padding:30rpx;box-shadow:0 4rpx 16rpx rgba(0,0,0,.05)}
.section-header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 30rpx 16rpx}
.section-title{font-size:32rpx;font-weight:bold;color:#333;display:flex;align-items:center}
.btn-primary{background:linear-gradient(135deg,#FFD93D 0%,#FF9A3C 100%);color:#333;font-size:30rpx;font-weight:bold;padding:20rpx 48rpx;border-radius:9999rpx;text-align:center;border:none}
.btn-primary::after{border:none}
.btn-secondary{background:#FFF;color:#FF9A3C;font-size:28rpx;padding:18rpx 40rpx;border-radius:9999rpx;border:2rpx solid #FFD93D;text-align:center}
.btn-secondary::after{border:none}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80rpx 40rpx}
.empty-icon{font-size:80rpx;margin-bottom:20rpx}.empty-text{font-size:28px;color:#999;margin-bottom:20rpx}
.loading-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:100rpx 40rpx}
.loading-icon{font-size:60rpx;margin-bottom:20rpx}.loading-text{font-size:26px;color:#999}
.progress-bar{width:100%;height:12rpx;background:#F0F0F0;border-radius:6rpx;overflow:hidden}
.progress-fill{height:100%;background:linear-gradient(90deg,#FFD93D 0%,#FF9A3C 100%);border-radius:6rpx;transition:width .3s ease}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:1000;display:flex;align-items:center;justify-content:center}
.modal-content{width:600rpx;max-height:80vh;background:#FFF;border-radius:24rpx;overflow:hidden;display:flex;flex-direction:column}
.modal-header{padding:30rpx;text-align:center;font-size:34rpx;font-weight:bold;border-bottom:1rpx solid #F0F0F0}
.modal-body{padding:30rpx;overflow-y:auto}
.modal-footer{display:flex;border-top:1rpx solid #F0F0F0}
.cancel-btn{color:#999;border-right:1rpx solid #F0F0F0!important}.confirm-btn{color:#FF9A3C;font-weight:bold}
.switch{width:96rpx;height:48rpx;border-radius:24rpx;background:#CCC;position:relative;transition:bg .3s}
.switch.on{background:#7ED957}
.switch-knob{position:absolute;top:4rpx;left:4rpx;width:40rpx;height:40rpx;border-radius:50%;background:#FFF;transition:transform .3s}
.switch.on .switch-knob{transform:translateX(48rpx)}