# 数据库配置
DATABASE_URL="postgresql://postgres:password@localhost:5432/xiaodaka?schema=public"

# 服务配置
PORT=3000
NODE_ENV=development

# 微信小程序配置（正式环境使用）
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret

# ===== 短信服务配置 =====
# 短信服务商：tencent（腾讯云）| aliyun（阿里云）| mock（开发模拟，不发送真实短信）
SMS_PROVIDER=mock

# --- 腾讯云 SMS 配置 ---
# 获取方式：腾讯云控制台 → 访问管理 → API 密钥管理
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
# 获取方式：腾讯云控制台 → 短信 → 国内短信 → 应用管理 → 应用列表
TENCENT_SMS_SDK_APPID=
# 短信签名（需在控制台审核通过，如"成长习惯打卡助手"）
TENCENT_SMS_SIGN_NAME=
# 验证码模板 ID（需在控制台审核通过，模板内容示例：您的验证码是{1}，{2}分钟内有效。）
TENCENT_SMS_TEMPLATE_ID=

# --- 阿里云 SMS 配置（备选）---
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
