<!-- 自定义底部导航栏 -->
<view class="custom-tabbar">
  <view
    wx:for="{{tabs}}"
    wx:key="key"
    class="tab-item {{current === item.key ? 'active' : ''}}"
    bindtap="switchTab"
    data-key="{{item.key}}"
  >
    <view class="tab-icon-wrap">
      <image
        class="tab-icon"
        src="{{current === item.key ? item.selectedIcon : item.icon}}"
      ></image>
    </view>
    <text class="tab-text" style="color: {{current === item.key ? selectedColor : color}}">{{item.text}}</text>
  </view>
</view>
